rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Submissions collection rules
    match /submissions/{submissionId} {
      // Allow any authenticated user to create a submission
      // Ideally, we'd also check that the data being submitted belongs to them
      allow create: if request.auth != null;
      
      // Only the admin can read, update, or delete submissions
      allow read, update, delete: if request.auth != null && 
                                   request.auth.token.email == 'josephbunton@live.co.uk' &&
                                   request.auth.token.email_verified == true;
    }
    // Gyms collection rules
    match /gyms/{gymId} {
      // Allow public reads - security is enforced at the API layer
      allow read: if true;
      // Only the admin can write gym data 
      allow write: if request.auth != null && 
                   request.auth.token.email == 'josephbunton@live.co.uk' &&
                   request.auth.token.email_verified == true;
    }
    
    // Pending Gym Listings rules
    match /pending_gym_listings/{listingId} {
      // Allow only authenticated users to create guest gym listings
      allow create: if request.auth != null;
      
      // Allow public read for search results
      allow read: if true;
      
      // Only the admin can update or delete pending listings
      allow update, delete: if request.auth != null && 
                                   request.auth.token.email == 'josephbunton@live.co.uk' &&
                                   request.auth.token.email_verified == true;
    }
    
    // Gym Bounties Collections
    match /bounties/{bountyId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null; // Allows Gym Owners to increment offersCount
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || request.auth.token.email == 'josephbunton@live.co.uk');
    }
    
    match /bountyOffers/{offerId} {
      allow read, create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.gymId;
    }
    
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == 'josephbunton@live.co.uk');
    }

    match /recent_activities/{activityId} {
      allow read, create: if true;
      allow update, delete: if false;
    }

    // Default rule: block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
